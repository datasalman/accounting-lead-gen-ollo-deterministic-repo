# Companies House Public Data API key (free).
# Get one at: https://developer.company-information.service.gov.uk/
# Auth is HTTP Basic — the key is the USERNAME and the password is EMPTY.
# Rate limit: 600 requests / 5 minutes (the pipeline paces itself at ~0.55s/call).
CH_API_KEY=your_companies_house_api_key_here

# Optional: path to the bulk "Free Company Data Product" CSV (or .zip).
# Defaults to ../BasicCompanyDataAsOneFile-YYYY-MM-01/...csv relative to this repo,
# i.e. the copy sitting alongside the repo in the Lead Gen folder.
# CH_BULK_CSV=C:\Users\you\Documents\...\BasicCompanyDataAsOneFile-2026-07-01.csv
